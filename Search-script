local activeMenu=nil
local function closeActiveMenu() if activeMenu then activeMenu:Destroy() activeMenu=nil end end
local function isNoKey(title,desc)
	local t=(title or ""):lower()
	local d=(desc or ""):lower()
	for _,w in{"key","keylink","linkvertise","lootlabs","fluxus key","require key"}do
		if t:find(w,1,true) or d:find(w,1,true) then return false end
	end
	return true
end
local function addResult(i,title,gameName,scriptCode,source)
	local r=mk("Frame",{Size=UDim2.new(1,0,0,62),BackgroundColor3=T.Row,LayoutOrder=i,ZIndex=7,Parent=SF}) cr(r,8)
	mk("UIStroke",{Color=Color3.fromRGB(180,180,210),Thickness=1,Parent=r})
	local srcColor=source=="ScriptBlox" and Color3.fromRGB(80,140,255) or Color3.fromRGB(255,140,40)
	local srcLbl=mk("TextLabel",{Size=UDim2.new(0,0,0,16),AutomaticSize=Enum.AutomaticSize.X,Position=UDim2.new(0,10,0,4),BackgroundColor3=srcColor,Text=" "..source.." ",TextColor3=Color3.fromRGB(255,255,255),TextSize=10,Font=Enum.Font.GothamBold,ZIndex=9,Parent=r}) cr(srcLbl,4)
	mk("TextLabel",{Size=UDim2.new(1,-80,0,22),Position=UDim2.new(0,10,0,22),BackgroundTransparency=1,Text=title,TextColor3=T.Text,TextSize=13,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8,Parent=r})
	mk("TextLabel",{Size=UDim2.new(1,-80,0,16),Position=UDim2.new(0,10,0,43),BackgroundTransparency=1,Text="🎮 "..(gameName or "Universal"),TextColor3=T.Sub,TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8,Parent=r})
	local playBtn=mk("TextButton",{Size=UDim2.new(0,40,0,40),Position=UDim2.new(1,-50,0.5,-20),BackgroundColor3=T.Btn,Text="▶",TextColor3=T.BtnText,TextSize=18,Font=Enum.Font.GothamBold,ZIndex=8,Parent=r}) cr(playBtn,8)
	connectBtn(playBtn,function()
		closeActiveMenu()
		local mini=mk("Frame",{Size=UDim2.new(0,160,0,84),Position=UDim2.new(1,-170,0,0),BackgroundColor3=T.Btn,ZIndex=15,Parent=r}) cr(mini,8)
		mk("UIStroke",{Color=T.Acc,Thickness=1.5,Parent=mini})
		activeMenu=mini
		local copyBtn=mk("TextButton",{Size=UDim2.new(1,-12,0,32),Position=UDim2.new(0,6,0,6),BackgroundColor3=T.Panel,Text="📋 Copy Loadstring",TextColor3=T.Text,TextSize=12,Font=Enum.Font.GothamBold,ZIndex=16,Parent=mini}) cr(copyBtn,6)
		local loadBtn2=mk("TextButton",{Size=UDim2.new(1,-12,0,32),Position=UDim2.new(0,6,0,46),BackgroundColor3=T.Green,Text="▶ Load Script",TextColor3=Color3.fromRGB(255,255,255),TextSize=12,Font=Enum.Font.GothamBold,ZIndex=16,Parent=mini}) cr(loadBtn2,6)
		connectBtn(copyBtn,function()
			if scriptCode:find("^https?://") then
				setclipboard('loadstring(game:HttpGet("'..scriptCode..'"))()')
				notify("📋 Copied loadstring!")
			else
				setclipboard(scriptCode)
				notify("📋 Copied script!")
			end
			closeActiveMenu()
		end)
		connectBtn(loadBtn2,function()
			closeActiveMenu()
			statusLbl.Text="⏳ Loading: "..title
			local ok2,err=pcall(function()
				if scriptCode:find("^https?://") then loadstring(game:HttpGet(scriptCode))()
				else loadstring(scriptCode)() end
			end)
			if ok2 then notify("✅ Loaded: "..title)
			else notify("❌ Lỗi: "..tostring(err):sub(1,40)) end
			statusLbl.Text="Nhập tên game để tìm script no-key"
		end)
	end)
end
connectBtn(searchBtn,function()
	local q=box.Text if q=="" then notify("❌ Nhập tên game!") return end
	closeActiveMenu()
	for _,v in SF:GetChildren()do if not v:IsA("UIListLayout") and not v:IsA("UIPadding") then v:Destroy() end end
	statusLbl.Text="⏳ Đang tìm..."
	local results={}
	local ok1,data1=pcall(function()
		return Http:JSONDecode(game:HttpGet("https://scriptblox-api-proxy.vercel.app/api/search?q="..Http:UrlEncode(q).."&max=15&mode=free&key=0"))
	end)
	if ok1 and data1 and data1.result and data1.result.scripts then
		for _,s in ipairs(data1.result.scripts)do
			if isNoKey(s.title,s.description) then
				table.insert(results,{title=s.title or "Script",game=s.game and s.game.name or "Universal",script=s.script or "",source="ScriptBlox"})
			end
		end
	end
	local ok2,data2=pcall(function()
		return Http:JSONDecode(game:HttpGet("https://rscripts.net/api/v2/scripts?q="..Http:UrlEncode(q).."&page=1&orderBy=views&free=true"))
	end)
	if ok2 and data2 and data2.scripts then
		for _,s in ipairs(data2.scripts)do
			if isNoKey(s.title,s.description) and s.rawScript then
				table.insert(results,{title=s.title or "Script",game=s.game and s.game.name or "Universal",script=s.rawScript,source="RScripts"})
			end
		end
	end
	if #results==0 then statusLbl.Text="❌ Không tìm thấy script no-key!"
	else
		statusLbl.Text="✅ "..#results.." script no-key"
		for i,v in ipairs(results)do addResult(i,v.title,v.game,v.script,v.source) end
	end
end)
