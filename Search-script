local function connectBtn(btn,cb)
	local db=false
	local function fire() if not db then db=true pcall(cb) task.delay(0.15,function()db=false end) end end
	btn.MouseButton1Click:Connect(fire)
	btn.TouchTap:Connect(fire)
end
local OpenBtn=mk("TextButton",{Size=UDim2.new(0,48,0,48),Position=UDim2.new(0,14,0.5,-24),BackgroundColor3=T.Btn,Text="✕",TextColor3=T.BtnText,TextSize=20,Font=Enum.Font.GothamBold,ZIndex=10,Parent=sg})
cr(OpenBtn,10)
RS.Heartbeat:Connect(function()
