end
local function addNumAction(label,desc,btnText,remote,remotetype)
	local row=mk("Frame",{Size=UDim2.new(1,0,0,80),BackgroundColor3=T.Row,ZIndex=8,Parent=SF}) cr(row,8)
	mk("UIStroke",{Color=T.Sep,Thickness=1,Parent=row})
	mk("TextLabel",{Size=UDim2.new(1,0,0,22),Position=UDim2.new(0,10,0,4),BackgroundTransparency=1,Text=label,TextColor3=T.Text,TextSize=13,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=9,Parent=row})
	mk("TextLabel",{Size=UDim2.new(1,0,0,16),Position=UDim2.new(0,10,0,24),BackgroundTransparency=1,Text=desc or "",TextColor3=T.Sub,TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=9,Parent=row})
	local box=mk("TextBox",{Size=UDim2.new(1,-110,0,26),Position=UDim2.new(0,10,0,46),BackgroundColor3=T.Input,PlaceholderText="Nhập số...",Text="5000000000000000",TextColor3=T.Text,PlaceholderColor3=T.Sub,TextSize=12,Font=Enum.Font.Gotham,ClearTextOnFocus=false,ZIndex=9,Parent=row}) cr(box,6)
	mk("UIPadding",{PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6),Parent=box})
	local setBtn=mk("TextButton",{Size=UDim2.new(0,82,0,26),Position=UDim2.new(1,-90,0,46),BackgroundColor3=T.Red,Text=btnText or "▶ Set",TextColor3=Color3.fromRGB(255,255,255),TextSize=11,Font=Enum.Font.GothamBold,ZIndex=9,Parent=row}) cr(setBtn,6)
	connectBtn(setBtn,function()
		local n=tonumber(box.Text)
		if not n then notify("❌ Nhập số hợp lệ!") return end
		local ok2,err=pcall(function()
			local r=remote
			if remotetype=="RF" then r:InvokeServer(n)
			else r:FireServer(n) end
		end)
		if ok2 then notify("✅ "..label..": "..box.Text)
		else notify("❌ Lỗi: "..tostring(err):sub(1,40)) end
	end)
	table.insert(Widgets,row)
end
local function addSpam(label,desc,remote,remotetype,args)
	local row=mk("Frame",{Size=UDim2.new(1,0,0,52),BackgroundColor3=T.Row,ZIndex=8,Parent=SF}) cr(row,8)
	mk("UIStroke",{Color=T.Sep,Thickness=1,Parent=row})
	mk("TextLabel",{Size=UDim2.new(1,-72,0,24),Position=UDim2.new(0,10,0,4),BackgroundTransparency=1,Text=label,TextColor3=T.Text,TextSize=13,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=9,Parent=row})
	mk("TextLabel",{Size=UDim2.new(1,-72,0,18),Position=UDim2.new(0,10,0,26),BackgroundTransparency=1,Text=desc or "",TextColor3=T.Sub,TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=9,Parent=row})
	local state=false
	local conn=nil
	local pill=mk("Frame",{Size=UDim2.new(0,50,0,24),Position=UDim2.new(1,-60,0.5,-12),ZIndex=9,Parent=row}) cr(pill,12)
	local knob=mk("Frame",{Size=UDim2.new(0,18,0,18),Position=UDim2.new(0,3,0.5,-9),BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=10,Parent=pill}) cr(knob,9)
	local function upd()
		pill.BackgroundColor3=state and T.ON or T.OFF
		knob.Position=state and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9)
	end
	upd()
	local pillBtn=mk("TextButton",{Size=UDim2.new(0,50,0,52),Position=UDim2.new(1,-60,0,0),BackgroundTransparency=1,Text="",ZIndex=11,Parent=row})
	connectBtn(pillBtn,function()
		state=not state upd()
		if state then
			conn=RS.Heartbeat:Connect(function()
				pcall(function()
					if remotetype=="RF" then
						if args then remote:InvokeServer(table.unpack(args))
						else remote:InvokeServer() end
					else
						if args then remote:FireServer(table.unpack(args))
						else remote:FireServer() end
					end
				end)
			end)
		else
			if conn then conn:Disconnect() conn=nil end
		end
	end)
	table.insert(Widgets,row)
end
local function renderTab(name) clearW() local fn=Pages[name] if fn then fn() end end
local function addTab(name,icon,fn)
	Pages[name]=fn
	local btn=mk("TextButton",{Size=UDim2.new(1,0,0,40),BackgroundTransparency=1,Text="",ZIndex=7,Parent=SideBar})
	local accent=mk("Frame",{Size=UDim2.new(0,3,0.7,0),Position=UDim2.new(0,0,0.15,0),BackgroundColor3=T.Red,Visible=false,ZIndex=8,Parent=btn}) cr(accent,2)
	mk("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=icon.." "..name,TextColor3=T.Sub,TextSize=12,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8,Parent=btn})
	mk("UIPadding",{PaddingLeft=UDim.new(0,10),Parent=btn})
	TabBtns[name]={btn=btn,accent=accent}
	connectBtn(btn,function()
		for n,tb in pairs(TabBtns)do tb.accent.Visible=false tb.btn:FindFirstChildOfClass("TextLabel").TextColor3=T.Sub end
		accent.Visible=true btn:FindFirstChildOfClass("TextLabel").TextColor3=T.Text
		ActiveTab=name renderTab(name)
	end)
end
