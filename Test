local function notify(msg)
	local f=mk("Frame",{Size=UDim2.new(0,280,0,44),Position=UDim2.new(0.5,-140,0,10),BackgroundColor3=T.Row,ZIndex=20,Parent=sg})
	cr(f,8) mk("UIStroke",{Color=T.Green,Thickness=1.5,Parent=f})
	mk("TextLabel",{Size=UDim2.new(1,-12,1,0),Position=UDim2.new(0,6,0,0),BackgroundTransparency=1,Text=msg,TextColor3=T.Text,TextSize=13,Font=Enum.Font.GothamBold,ZIndex=21,Parent=f})
	game:GetService("Debris"):AddItem(f,3)
end
local function connectBtn(btn,cb)
	local db=false
	local function fire() if not db then db=true pcall(cb) task.delay(0.15,function()db=false end) end end
	btn.MouseButton1Click:Connect(fire) btn.TouchTap:Connect(fire)
end
local OpenBtn=mk("TextButton",{Size=UDim2.new(0,48,0,48),Position=UDim2.new(0,14,0.5,-24),BackgroundColor3=T.Red,Text="☰",TextColor3=Color3.fromRGB(255,255,255),TextSize=22,Font=Enum.Font.GothamBold,ZIndex=10,Parent=sg})
cr(OpenBtn,10) mk("UIStroke",{Color=T.Green,Thickness=2,Parent=OpenBtn})
local drag,dInput,dStart,dPos=false
OpenBtn.InputBegan:Connect(function(i)
	if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
		drag=true dStart=i.Position dPos=OpenBtn.Position
		i.Changed:Connect(function()if i.UserInputState==Enum.UserInputState.End then drag=false end end)
	end
end)
OpenBtn.InputChanged:Connect(function(i)
	if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseMovement then dInput=i end
end)
UIS.InputChanged:Connect(function(i)
	if i==dInput and drag then
		local d=i.Position-dStart
		OpenBtn.Position=UDim2.new(dPos.X.Scale,dPos.X.Offset+d.X,dPos.Y.Scale,dPos.Y.Offset+d.Y)
	end
end)
