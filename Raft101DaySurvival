-- Logic
local bringEnabled = false
local connection = nil

local function getAllItems()
    local items = {}
    local workspace = game:GetService("Workspace")
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:IsDescendantOf(lp.Character or Instance.new("Folder")) then
            local hasCollect = obj:FindFirstChildWhichIsA("ClickDetector")
                or obj:FindFirstChild("Collect")
                or obj:FindFirstChild("PickUp")
                or (obj.Name:lower():find("item") or obj.Name:lower():find("wood") or obj.Name:lower():find("plank")
                or obj.Name:lower():find("plastic") or obj.Name:lower():find("barrel") or obj.Name:lower():find("scrap")
                or obj.Name:lower():find("rope") or obj.Name:lower():find("leaf") or obj.Name:lower():find("stone")
                or obj.Name:lower():find("food") or obj.Name:lower():find("fruit") or obj.Name:lower():find("resource"))
            if hasCollect then
                table.insert(items, obj)
            end
        end
    end
    return items
end

local function bringItems()
    local char = lp.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    for _, item in ipairs(getAllItems()) do
        if item and item.Parent then
            item.CFrame = hrp.CFrame * CFrame.new(0, 0, -3)
        end
    end
end

ToggleBtn.MouseButton1Click:Connect(function()
    bringEnabled = not bringEnabled
    if bringEnabled then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(30, 150, 30)
        ToggleBtn.Text = "Bring Item: BẬT"
        StatusLabel.Text = "Trạng thái: BẬT ✔"
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        connection = RunService.Heartbeat:Connect(function()
            if bringEnabled then
                bringItems()
            end
        end)
    else
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(180, 30, 30)
        ToggleBtn.Text = "Bring Item: TẮT"
        StatusLabel.Text = "Trạng thái: TẮT"
        StatusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
        if connection then
            connection:Disconnect()
            connection = nil
        end
    end
end)
