local function addSlider(label,min,max,def,cb)
	local row=mk("Frame",{Size=UDim2.new(1,0,0,64),BackgroundColor3=T.Row,ZIndex=8,Parent=SF}) cr(row,8)
	mk("UIStroke",{Color=T.Sep,Thickness=1,Parent=row})
	local valLbl=mk("TextLabel",{Size=UDim2.new(1,-16,0,22),Position=UDim2.new(0,12,0,5),BackgroundTransparency=1,Text=label.." : "..def,TextColor3=T.Text,TextSize=13,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=9,Parent=row})
	local track=mk("Frame",{Size=UDim2.new(1,-24,0,6),Position=UDim2.new(0,12,0,34),BackgroundColor3=T.Sep,ZIndex=9,Parent=row}) cr(track,3)
	local fill=mk("Frame",{Size=UDim2.new((def-min)/(max-min),0,1,0),BackgroundColor3=T.Acc,ZIndex=10,Parent=track}) cr(fill,3)
	local knob=mk("Frame",{Size=UDim2.new(0,18,0,18),Position=UDim2.new((def-min)/(max-min),0,0.5,-9),BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=11,Parent=track}) cr(knob,9)
	local sliding=false
	local function setVal(x)
		local abs=track.AbsolutePosition.X
		local w=track.AbsoluteSize.X
		local pct=math.clamp((x-abs)/w,0,1)
		local val=math.floor(min+(max-min)*pct)
		fill.Size=UDim2.new(pct,0,1,0)
		knob.Position=UDim2.new(pct,-9,0.5,-9)
		valLbl.Text=label.." : "..val
		if cb then pcall(cb,val) end
	end
	track.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
			sliding=true setVal(i.Position.X)
		end
	end)
	UIS.InputChanged:Connect(function(i)
		if sliding and (i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseMovement) then
			setVal(i.Position.X)
		end
	end)
	UIS.InputEnded:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end
	end)
	table.insert(Widgets,row)
end
local function renderTab(name) clearW() local fn=Pages[name] if fn then fn() end end
local function addTab(name,icon,fn)
	Pages[name]=fn
	local btn=mk("TextButton",{Size=UDim2.new(1,0,0,42),BackgroundTransparency=1,Text="",ZIndex=7,Parent=SideBar})
	local accent=mk("Frame",{Size=UDim2.new(0,4,0.7,0),Position=UDim2.new(0,-2,0.15,0),BackgroundColor3=T.Acc,Visible=false,ZIndex=8,Parent=btn}) cr(accent,2)
	mk("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=icon.." "..name,TextColor3=T.Sub,TextSize=13,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8,Parent=btn})
	mk("UIPadding",{PaddingLeft=UDim.new(0,12),Parent=btn})
	TabBtns[name]={btn=btn,accent=accent}
	connectBtn(btn,function()
		for n,tb in pairs(TabBtns)do
			tb.accent.Visible=false
			tb.btn:FindFirstChildOfClass("TextLabel").TextColor3=T.Sub
		end
		accent.Visible=true
		btn:FindFirstChildOfClass("TextLabel").TextColor3=T.Text
		ActiveTab=name
		renderTab(name)
	end)
end
