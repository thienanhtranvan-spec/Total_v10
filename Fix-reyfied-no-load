	mk("TextLabel",{Size=UDim2.new(1,-72,0,20),Position=UDim2.new(0,12,0,30),BackgroundTransparency=1,Text=desc or "",TextColor3=T.Sub,TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=9,Parent=row})
	local pill=mk("Frame",{Size=UDim2.new(0,50,0,26),Position=UDim2.new(1,-62,0.5,-13),ZIndex=9,Parent=row}) cr(pill,13)
	local knob=mk("Frame",{Size=UDim2.new(0,20,0,20),Position=UDim2.new(0,3,0.5,-10),BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=10,Parent=pill}) cr(knob,10)
	local function upd()
		local s=ToggleStates[id]
		pill.BackgroundColor3=s and T.ON or T.OFF
		knob.Position=s and UDim2.new(1,-23,0.5,-10) or UDim2.new(0,3,0.5,-10)
	end
	upd()
	local btn=mk("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=11,Parent=row})
	connectBtn(btn,function()
		ToggleStates[id]=not ToggleStates[id]
		upd()
		if cb then pcall(cb,ToggleStates[id]) end
	end)
	table.insert(Widgets,row)
end
