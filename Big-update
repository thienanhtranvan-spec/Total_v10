			for _,s in ipairs(data1.result.scripts)do
				table.insert(results,{title=s.title or "Script",game=s.game and s.game.name or "Universal",script=s.script,source="ScriptBlox"})
			end
		end
		local ok2,data2=pcall(function()
			return Http:JSONDecode(game:HttpGet("https://rscripts.net/api/v2/scripts?q="..Http:UrlEncode(q).."&page=1&orderBy=views&free=true"))
		end)
		if ok2 and data2 and data2.scripts then
			for _,s in ipairs(data2.scripts)do
				if s.rawScript then
					table.insert(results,{title=s.title or "Script",game=s.game and s.game.name or "Universal",script=s.rawScript,source="RScripts"})
				end
			end
		end
		if #results==0 then
			statusLbl.Text="❌ Không tìm thấy script nào!"
		else
			statusLbl.Text="✅ Tìm thấy "..#results.." script"
			for i,v in ipairs(results)do
				addResult(i,v.title,v.game,v.script,v.source)
			end
		end
	end)
